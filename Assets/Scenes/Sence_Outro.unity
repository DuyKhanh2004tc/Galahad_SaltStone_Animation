  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "HI\u1EC6P S\u0128 V\xC0 VI\xCAN \u0110\xC1 MU\u1ED0I\r\n(The Knight and
    the Salt Stone)\r\n\r\n------------------------------\r\n\r\nA SHORT GAME CINEMATIC\r\n\r\n------------------------------\r\n\r\nFILM
    DESIGN\r\n\nB\xF9i Duy Kh\xE1nh\r\nTr\u01B0\u01A1ng Tr\u1EA7n C\u01B0\u1EDDng\r\n\r\n------------------------------\r\n\r\nVOICE
    ACTING\r\n\r\nGalahad\r\nTr\u01B0\u01A1ng Tr\u1EA7n C\u01B0\u1EDDng\r\n\r\nVillage
    Chief (Tr\u01B0\u1EDFng L\xE0ng)\r\nB\xF9i Duy Kh\xE1nh\r\n\r\n------------------------------\r\n\r\nANIMATION
    & VISUAL ASSETS\r\n\r\nitch.io\r\nUnity Asset Store\r\nPixel Art Community Assets\r\n\r\n------------------------------\r\n\r\nSOUND
    EFFECTS & MUSIC\r\n\r\nPixabay\r\nTikTok Sound Library\r\nYouTube Audio Library\r\n\r\nAdditional
    Sound Resources\r\nOpenGameArt.org\r\n\r\n------------------------------\r\n\r\nGAME
    ENGINE\r\n\r\nUnity Engine\r\n\r\n------------------------------\r\n\r\nSPECIAL
    THANKS\r\nNguy\u1EC5n Song Anh Khu\xEA\n\r\n------------------------------\r\n\r\nTHANK
    YOU FOR WATCHING\r\n\r\n------------------------------\r"
  m_isRightToLeft: 0
